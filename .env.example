# ═══════════════════════════════════════════════
#  SIVRA — Environment Variables
#  Copy to .env for local dev, or set in Railway
# ═══════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────

# JWT signing secret — MUST be set (server won't start without it)
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── DATABASE ────────────────────────────────────

# Option A: Turso cloud database (recommended for production)
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Option B: Local SQLite file (default — auto-created)
# DB_PATH=file:./sivra.db

# ── STRIPE PAYMENTS ─────────────────────────────

# Get these from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── EMAIL ───────────────────────────────────────

# Supported providers: resend, sendgrid, postmark
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxx
# (or SENDGRID_API_KEY / POSTMARK_API_KEY)
# EMAIL_FROM=noreply@yourdomain.com

# Admin email — receives new order notifications
# ADMIN_EMAIL=you@example.com

# ── URLS ────────────────────────────────────────

# Your live store URL (used in emails, sitemap, links)
# STORE_URL=https://your-app.up.railway.app

# Your store slug (for sitemap generation)
# STORE_SLUG=your-store-slug

# CORS — comma-separated allowed origins
# FRONTEND_URL=https://your-app.up.railway.app

# ── SERVER ──────────────────────────────────────

PORT=3000
NODE_ENV=development
# Set to 'production' on Railway
